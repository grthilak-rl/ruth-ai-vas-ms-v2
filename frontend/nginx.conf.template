# Ruth AI Frontend — nginx config template.
#
# This file is processed by the nginx:alpine entrypoint at container
# start: envsubst replaces ${VAS_PROXY_URL} from the container's env
# and writes the result to /etc/nginx/conf.d/default.conf before
# nginx boots. Other shell-style $var references in this template
# (e.g. $host, $remote_addr) are nginx's own runtime variables —
# envsubst only touches ${BRACED} forms, so they pass through unchanged.
#
# VAS_PROXY_URL must point to the VAS backend reachable from inside
# the Ruth frontend container. In the merged deployment the
# integration compose injects:
#   VAS_PROXY_URL=http://host.docker.internal:${VAS_BACKEND_PORT}
# mirroring Ruth backend's own VAS_BASE_URL — same target, same DNS
# shim (extra_hosts: host.docker.internal:host-gateway). The
# Dockerfile sets a default of http://localhost:8085 so the image
# still boots if no env is injected.

server {
    listen 80;
    listen [::]:80;
    server_name localhost;

    # Root directory for static files
    root /usr/share/nginx/html;
    index index.html;

    # Gzip compression
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_proxied expired no-cache no-store private auth;
    gzip_types
        text/plain
        text/css
        text/xml
        text/javascript
        application/x-javascript
        application/xml
        application/xml+rss
        application/javascript
        application/json;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;

    # Proxy API requests to Ruth AI Backend
    location /api/ {
        proxy_pass http://ruth-ai-vas-backend:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 30s;
        proxy_send_timeout 180s;  # Increased for chat LLM queries
        proxy_read_timeout 180s;  # Increased for chat LLM queries
    }

    # Proxy internal endpoints
    location /internal/ {
        proxy_pass http://ruth-ai-vas-backend:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Proxy metrics endpoint
    location /metrics {
        proxy_pass http://ruth-ai-vas-backend:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    # Proxy VAS API requests. The browser hits /v2/* on the Ruth
    # frontend; nginx forwards to VAS. VAS_PROXY_URL is the only
    # env-driven value in this template — see header.
    location /v2/ {
        proxy_pass ${VAS_PROXY_URL};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 30s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    # Static assets with cache headers
    location /assets/ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }

    # Favicon and other static files
    location ~* \.(ico|png|jpg|jpeg|gif|svg|woff|woff2|ttf|eot)$ {
        expires 1M;
        add_header Cache-Control "public";
        try_files $uri =404;
    }

    # SPA fallback - serve index.html for all routes not matched
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Health check endpoint for container orchestration
    location /nginx-health {
        access_log off;
        return 200 "healthy\n";
        add_header Content-Type text/plain;
    }
}
